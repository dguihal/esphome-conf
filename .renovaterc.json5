{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    ':separateMajorReleases',
    ':combinePatchMinorReleases',
  ],
  timezone: 'Europe/Paris',
  labels: [
    'dependencies',
    'esphome',
  ],
  packageRules: [
    {
      description: 'Automerge uniquement pour les outils de CI (GitHub Actions)',
      matchManagers: [
        'github-actions',
      ],
      automerge: true,
      automergeType: 'pr',
      platformAutomerge: true,
    },
    {
      description: 'Validation manuelle requise pour ESPHome et les composants externes',
      matchPackageNames: [
        'esphome/esphome',
      ],
      matchManagers: [
        'custom.regex',
      ],
      automerge: false,
    },
  ],
  customManagers: [
    {
      customType: 'regex',
      description: 'Suivi des composants externes via Tags ou SHAs',
      managerFilePatterns: [
        '/^.*\\.yaml$/',
        '/^common/.*\\.yaml$/',
      ],
      matchStrings: [
        'source:\\s*github://(?<depName>[^@\\s]+)@(?<currentValue>[^\\s]+)',
      ],
      datasourceTemplate: 'github-tags',
      versioningTemplate: 'docker',
    },
    {
      customType: 'regex',
      description: "Détecte l'image Docker ESPHome dans les workflows GitHub",
      managerFilePatterns: [
        '/^\\.github/workflows/.*\\.yml$/',
      ],
      matchStrings: [
        'esphome/esphome:(?<currentValue>[^\\s"\']+)',
      ],
      depNameTemplate: 'esphome/esphome',
      datasourceTemplate: 'docker',
    },
  ],
}
